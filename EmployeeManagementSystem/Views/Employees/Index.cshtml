@model IEnumerable<EmployeeManagementSystem.Models.Employee>
@if (TempData["Success"] != null)
{
    <div class="alert alert-success rounded-4">
        <i class="bi bi-check-circle"></i> @TempData["Success"]
    </div>
}
@{
    ViewData["Title"] = "Employees";
}

<div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-3">
    <div>
        <h3 class="fw-bold mb-0">Employees</h3>
        <div class="text-muted">Directory & record management</div>
    </div>
    <a asp-controller="Employees" asp-action="Create" class="btn btn-primary">
        <i class="bi bi-person-plus"></i> Add Employee
    </a>
    
</div>

<div class="card rounded-4">
    <div class="card-body">
        <div class="row g-2 align-items-center mb-3">
            <div class="col-md-6">
                <div class="input-group">
                    <span class="input-group-text bg-white border"><i class="bi bi-search"></i></span>
                    <input id="searchBox" class="form-control" placeholder="Search by name, email, department, role..." />
                </div>
            </div>
            <div class="col-md-6 text-md-end">
                <span class="text-muted small" id="countLabel"></span>
            </div>
        </div>

        <div class="table-responsive">
            <table class="table table-hover align-middle" id="empTable">
                <thead>
                    <tr>
                        <th>Name</th>
                        <th>Email</th>
                        <th>Department</th>
                        <th>Role</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="fw-semibold">@item.Name</td>
                            <td>@item.Email</td>
                            <td><span class="badge text-bg-secondary">@item.Department</span></td>
                            <td><span class="badge text-bg-info">@item.Role</span></td>
                            <td class="text-end">
                                <a asp-controller="Employees" asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary">
                                    <i class="bi bi-eye"></i>
                                </a>

                                <a asp-controller="Employees" asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">
                                    <i class="bi bi-pencil-square"></i>
                                </a>

                                <a asp-controller="Employees" asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger">
                                    <i class="bi bi-trash"></i>
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        @if (!Model.Any())
        {
            <div class="text-center text-muted py-4">
                No employees found. Click <b>Add Employee</b> to create one.
            </div>
        }
    </div>
</div>

<script>
    const searchBox = document.getElementById("searchBox");
    const table = document.getElementById("empTable");
    const countLabel = document.getElementById("countLabel");

    function updateCount() {
        const rows = table?.querySelectorAll("tbody tr") || [];
        let visible = 0;
        rows.forEach(r => { if (r.style.display !== "none") visible++; });
        countLabel.textContent = rows.length ? `${visible} / ${rows.length} shown` : "";
    }

    function applySearch() {
        const q = (searchBox.value || "").toLowerCase();
        const rows = table.querySelectorAll("tbody tr");
        rows.forEach(r => r.style.display = r.innerText.toLowerCase().includes(q) ? "" : "none");
        updateCount();
    }

    searchBox?.addEventListener("input", applySearch);
    updateCount();
</script>