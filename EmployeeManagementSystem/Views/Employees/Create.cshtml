@model EmployeeManagementSystem.Models.Employee

@{
    ViewData["Title"] = "Add Employee";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h3 class="fw-bold mb-0">Add Employee</h3>
        <div class="text-muted">Create a new employee record</div>
    </div>

    <a asp-action="Index" class="btn btn-outline-secondary">
        <i class="bi bi-arrow-left"></i> Back to Employees
    </a>
</div>

<div class="card shadow-sm rounded-4">
    <div class="card-body p-4">

        <form asp-action="Create" method="post">

            <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

            <div class="row g-3">

                <!-- Name -->
                <div class="col-md-6">
                    <label asp-for="Name" class="form-label fw-semibold"></label>
                    <div class="input-group">
                        <span class="input-group-text">
                            <i class="bi bi-person"></i>
                        </span>
                        <input asp-for="Name" class="form-control" placeholder="Enter full name" />
                    </div>
                    <span asp-validation-for="Name" class="text-danger small"></span>
                </div>

                <!-- Email -->
                <div class="col-md-6">
                    <label asp-for="Email" class="form-label fw-semibold"></label>
                    <div class="input-group">
                        <span class="input-group-text">
                            <i class="bi bi-envelope"></i>
                        </span>
                        <input asp-for="Email" class="form-control" placeholder="employee@company.com" />
                    </div>
                    <span asp-validation-for="Email" class="text-danger small"></span>
                </div>

                <!-- Department Dropdown -->
                <div class="mb-3">
                    <label class="form-label">Department</label>
                    <select id="department" asp-for="Department" class="form-select">
                        <option value="">Select Department</option>
                        <option value="Engineering">Engineering</option>
                        <option value="Human Resources">Human Resources</option>
                        <option value="Finance">Finance</option>
                        <option value="Marketing">Marketing</option>
                        <option value="Operations">Operations</option>
                        <option value="IT Support">IT Support</option>
                    </select>
                </div>

                <!-- Role Dropdown -->
                <div class="mb-3">
                    <label class="form-label">Role</label>
                    <select id="role" asp-for="Role" class="form-select">
                        <option value="">Select Role</option>
                    </select>
                </div>

            </div>

            <hr class="my-4" />

            <!-- Buttons -->
            <div class="d-flex gap-2">

                <button type="submit" class="btn btn-primary px-4">
                    <i class="bi bi-check-circle"></i> Create Employee
                </button>

                <a asp-action="Index" class="btn btn-outline-secondary px-4">
                    Cancel
                </a>

            </div>

        </form>

    </div>
</div>
<script>

    const rolesByDepartment = {

    "Engineering": [
    "Intern",
    "Software Engineer",
    "QA Engineer",
    "DevOps Engineer"
    ],

    "Human Resources": [
    "Intern",
    "HR Manager",
    "Recruiter",
    "HR Executive"
    ],

    "Finance": [
    "Intern",
    "Accountant",
    "Financial Analyst",
    "Auditor"
    ],

    "Marketing": [
    "Intern",
    "Marketing Manager",
    "SEO Specialist",
    "Content Strategist"
    ],

    "Operations": [
    "Intern",
    "Operations Manager",
    "Logistics Coordinator"
    ],

    "IT Support": [
    "Intern",
    "IT Support Engineer",
    "System Administrator",
    "Network Engineer"
    ]

    };

    const departmentDropdown = document.getElementById("department");
    const roleDropdown = document.getElementById("role");

    departmentDropdown.addEventListener("change", function () {

        const selectedDepartment = this.value;

        roleDropdown.innerHTML = '<option value="">Select Role</option>';

        if (rolesByDepartment[selectedDepartment]) {

            rolesByDepartment[selectedDepartment].forEach(function(role){

                const option = document.createElement("option");
                option.value = role;
                option.text = role;

                roleDropdown.appendChild(option);

            });

        }

    });

</script>
@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}